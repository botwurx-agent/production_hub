# Supabase project connection (public values, safe for the browser).
# Row-level security enforces all access rules; never put service keys here.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Supabase service-role key. Server-only, NEVER exposed to the browser.
# Required for the client review portal (/r, /c) and token-gated file access,
# which read via a service client gated by an unguessable token. Without this,
# the review portal shows "not configured".
SUPABASE_SERVICE_ROLE_KEY=

# Canonical site origin (optional). Used to build absolute links (share links,
# OAuth redirects) when the request origin is not reliable.
NEXT_PUBLIC_SITE_URL=

# Google OAuth (Gmail + Calendar + Drive + Chat connectors). Server-only.
# Create an OAuth client in Google Cloud (see docs/DEVELOPMENT.md).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Slack OAuth (Slack connector). Server-only. Create a Slack app
# (see docs/DEVELOPMENT.md).
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Figma OAuth (Figma connector). Server-only. App scope: file_content:read.
FIGMA_CLIENT_ID=
FIGMA_CLIENT_SECRET=

# FreshBooks OAuth (billing connector). ON HOLD; only needed if billing is
# resumed. Server-only.
FRESHBOOKS_CLIENT_ID=
FRESHBOOKS_CLIENT_SECRET=

# AI features (optional). Provide one provider. AI_PROVIDER forces a choice.
# OPENAI_API_KEY (+ optional OPENAI_MODEL, default gpt-5-mini), or ANTHROPIC_API_KEY.
AI_PROVIDER=
OPENAI_API_KEY=
OPENAI_MODEL=
ANTHROPIC_API_KEY=

# Error monitoring (Sentry). Everything is inert until NEXT_PUBLIC_SENTRY_DSN is
# set. ORG/PROJECT/AUTH_TOKEN are only needed to upload source maps at build
# time (set them in Vercel + CI, not locally).
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Transactional email (Resend). Needed to email call sheets, review requests,
# and invites from the app. Inert until both are set. EMAIL_FROM must be a
# verified sender on your domain, e.g. "Studio Flows <hello@studio-flows.com>".
RESEND_API_KEY=
EMAIL_FROM=
